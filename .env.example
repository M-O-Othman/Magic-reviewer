# BigQuery Configuration
BQ_PROD_PROJECT=your-bigquery-project-id
BQ_EXECUTABLE_PATH=C:\path\to\bq.cmd
BQ_DATASET=your-project.your_dataset
CUSTOMER_LOOKUP_TABLE=your-project.your_dataset.dim_customer_lookup_archive

# LLM Configuration
LLM_DEV_PROJECT=your-llm-project-id
LLM_LOCATION=europe-west4
LLM_MODEL=gemini-2.5-pro

# Proxy Configuration (leave empty if not needed)
HTTP_PROXY=
HTTPS_PROXY=

# Flask Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
